# Spotify API credentials (create app at https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# User auth: run `npx tsx scripts/get-refresh-token.ts` once to get a refresh token
SPOTIFY_REFRESH_TOKEN=
SPOTIFY_USERNAME=
SPOTIFY_EMAIL=
# Optional: redirect URI for OAuth (default: http://localhost:8888/callback)
# SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# Playlist IDs (find in the Spotify app URL or share link)
PARENT_SUBWAY_PLAYLIST_ID=
CHILD_PLAYLIST_CALM_ID=
CHILD_PLAYLIST_BUSY_ID=
