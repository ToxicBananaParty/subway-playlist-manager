{
  "name": "subway-playlist-manager",
  "version": "1.0.0",
  "description": "Manages Subway Playlists: Slow, Busy, and a master containing all songs from both.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc",
    "format": "prettier --write .",
    "lint": "eslint . --max-warnings 0",
    "prepare": "husky"
  },
  "keywords": [
    "spotify",
    "playlist"
  ],
  "license": "MIT",
  "dependencies": {
    "@spotify/web-api-ts-sdk": "^1.2.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.9.0",
    "eslint": "^9.15.0",
    "husky": "^9.1.7",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0"
  }
}
